# LLM Configuration
OPENAI_API_KEY=sk-...
# Or for Anthropic:
# ANTHROPIC_API_KEY=sk-ant-...

# DSPy LLM provider: "openai" | "anthropic" | "ollama"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Database
# SQLite (default for local dev):
DATABASE_URL=sqlite+aiosqlite:///./autocourse.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/autocourse

# Vector Store
CHROMA_PERSIST_DIR=./data/chroma

# Embeddings model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# App
APP_ENV=development
LOG_LEVEL=INFO
