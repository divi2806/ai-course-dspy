# LLM Configuration — uncomment the provider you want to use

# Gemini (recommended)
# GEMINI_API_KEY=your-gemini-api-key
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash

# OpenAI
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-haiku-20241022

# Ollama (local, free)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2

LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# Database
# SQLite (default for local dev):
DATABASE_URL=sqlite+aiosqlite:///./autocourse.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/autocourse

# Vector Store
CHROMA_PERSIST_DIR=./data/chroma

# Embeddings model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# App
APP_ENV=development
LOG_LEVEL=INFO
