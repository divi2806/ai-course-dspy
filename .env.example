# Copy this to .env and fill in your values.
# Only one LLM provider block needs to be active at a time.

# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── LLM Provider ─────────────────────────────────────────────────────────
# Uncomment one block and fill in the key.

# OpenCode Zen (access to many models via one key)
# LLM_PROVIDER=opencode
# LLM_MODEL=kimi-k2.5
# OPENCODE_API_KEY=sk-...

# Gemini
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=...

# OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Anthropic
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-haiku-20241022
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local, free — install ollama and pull a model first)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ── Perplexity ────────────────────────────────────────────────────────────
# Required only for POST /ingest/topic (internet research feature).
# PERPLEXITY_API_KEY=pplx-...

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./autocourse.db
# PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/autocourse

# ── Misc (safe to leave as-is) ────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=64
